---
// components/home/FeaturedProjects.astro

import { getFeaturedProjects } from "../../lib/projects";
import { t } from "i18n:astro";

const lang = Astro.currentLocale ?? "en";
const featured = await getFeaturedProjects(lang);
---

<section id="projects" class="py-24">
  <div class="max-w-7xl mx-auto px-6">
    <div class="flex justify-between items-center mb-8">
      <h3 class="text-sm uppercase text-accent">// 02_featured_projects</h3>
      <a href="/projects" class="text-sm text-zinc-500">{t("projects.viewAll")} +</a>
    </div>
    {featured.map((project) => (
      <div class="grid md:grid-cols-2 gap-8 mb-12 border border-zinc-800 rounded-lg p-6">
        <img src={project.image} alt={project.title} class="rounded" />
        <div>
          <h4 class="font-bold text-lg">{project.title}</h4>
          <p class="text-zinc-400 mt-2">{project.description}</p>
          <div class="flex gap-2 mt-4 flex-wrap">
            {project.languages.map((lang) => (
              <span class="bg-accent/20 text-accent text-xs px-2 py-1 rounded-full">{lang}</span>
            ))}
          </div>
          <div class="flex gap-4 mt-4 text-accent text-sm">
            {project.caseStudy && <a href={`/projects/${project.slug}`}>{t("projects.caseStudy")} →</a>}
            {project.repository && <a href={project.repository} target="_blank">{t("projects.github")} ↗</a>}
          </div>
        </div>
      </div>
    ))}
  </div>
</section>
