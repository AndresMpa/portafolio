---
// src/components/home/Community.astro
import { locale, t } from "i18n:astro";
import { getCommunity } from "../../lib/community";
import { talks } from "../../data/talks";

import ubuco from "../../assets/ubuco.png";
import forest from "../../assets/forest.png";
import flisol from "../../assets/flisol.png";

const iconMap: Record<string, ImageMetadata> = {
  "ubuntu-colombia": ubuco,
  forest: forest,
  flisol: flisol,
};

const entries = await getCommunity(locale);
---

<section id="open-source" class="py-24">
  <div class="max-w-7xl mx-auto px-6">
    <h3 class="text-sm uppercase text-accent mb-8">// 04_open_source_&_community</h3>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
      {entries.map((entry) => (
        <article class="border border-zinc-800 p-6 rounded">
          <img src={iconMap[entry.slug].src} alt={entry.organization} class="w-10 h-10 mb-4" />
          <h4 class="font-bold">{entry.organization}</h4>
          <p class="text-accent text-sm">{entry.role}</p>
          <p class="text-zinc-500 text-xs">
            {entry.startDate}{entry.endDate ? ` — ${entry.endDate}` : " — Present"}
          </p>
        </article>
      ))}
      <article class="border border-zinc-800 p-6 rounded">
        <h4 class="font-bold">And more</h4>
        <p class="text-zinc-400 text-sm">
          Speaker, mentor and open source enthusiast — {talks.length} talks and events
        </p>
      </article>
    </div>
  </div>
</section>
