function buildEntry(talk: TalkEntry): TableItemProps[] {
  return [
    { type: "title", ref: false, bolder: false, context: talk.title },
    { type: "title", ref: false, bolder: true, context: talk.kind },
    { type: "chip", ref: false, bolder: false, context: talk.tags },
    { type: "reference", ref: true, bolder: false, context: talk.url },
    { type: "title", ref: false, bolder: false, context: talk.year },
  ];
}

const entries: Array<TableItemProps[]> = talks.map(buildEntry);
---

<section id="communities">
  <div class="flex flex-row">
    <article class="hidden md:block bg-accent p-12">
      <h2 class="text-9xl font-bold p-16 uppercase">
        Think <br />
        Out <br />
        Of <br />
        Code
      </h2>
    </article>
    <article class="flex flex-col items-end my-6 p-6 pr-12">
      <h3 class="text-4xl mb-6 uppercase text-accent">
        {t("community.title")}
      </h3>
      <p class="text-right w-10/12 text-2xl py-6">
        {t("community.description1")}
        <strong class="text-accent">{t("community.key1")}</strong>, {
          t("community.description2")
        }
        <strong class="text-accent">{t("community.key2")}</strong>
        {t("community.description3")}<strong class="text-accent">
          {t("community.key3")}
        </strong>{t("community.description4")}
        <strong class="text-accent">{t("community.key4")}</strong>
        {t("community.description5")}
        <strong class="text-accent">
          {t("community.key5")}
        </strong>
        {t("community.description6")}
      </p>
      <div class="md:mt-auto mt-12 flex">
        {
          communitiesData.map((data) => (
            <SocialLink
              icon={data.icon}
              link={data.link}
              alt={data.alt}
              useSvg={false}
              width={65}
            />
          ))
        }
      </div>
    </article>
  </div>

  <article class="overflow-x-auto mx-auto">
    <BadgeList headers={headers} entries={entries} />
  </article>
</section>
