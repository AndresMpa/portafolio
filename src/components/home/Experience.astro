---
// src/components/home/Experience.astro

import { locale } from "i18n:astro";
import { t } from "i18n:astro";

import { getExperience } from "../../lib/experience";

const lang = Astro.currentLocale ?? "en";
const merged = (await getExperience(lang)).slice(0, 3);
---

<section id="experience" class="py-4">
  <div class="max-w-7xl mx-auto px-6">
    <h3 class="text-sm uppercase text-accent mb-8">// 03_experience</h3>
    <div class="relative border-l border-zinc-800 pl-8 space-y-10">
      {merged.map((item) => (
        <div class="relative">
          <span class="absolute -left-[2.35rem] w-3 h-3 bg-accent rounded-full"></span>
          <p class="text-accent text-sm">
            {item.startDate.slice(0, 4)} - {item.endDate ? item.endDate.slice(0, 4) : t("experience.present")}
          </p>
          <h4 class="font-bold">{item.role}</h4>
          <p class="text-zinc-500">{item.company}</p>
        </div>
      ))}
    </div>
    <a href="/experience" class="text-accent text-sm mt-8 inline-block">
      {t("experience.viewAll")} →
    </a>
  </div>
</section>
