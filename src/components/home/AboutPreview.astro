---
// src/components/home/AboutPreview.astro

import { getEntry } from "astro:content";
import { locale } from "i18n:astro";

const lang = Astro.currentLocale ?? "en";
const about = await getEntry("about", lang);
const { whoami, excerpt } = about.data;
---

<section class="py-24">
  <div class="max-w-7xl mx-auto px-6 grid md:grid-cols-2 gap-12">
    <div class="border border-zinc-800 rounded-lg bg-black/40 p-6 font-mono text-sm">
      <p><span class="text-accent">andres@dev</span>:-$ whoami</p>
      <p class="mt-2 text-zinc-400">name: Andrés M. Prieto</p>
      <p class="text-zinc-400">role: {whoami.role}</p>
      <p class="text-zinc-400">location: {whoami.location}</p>
      <p class="text-zinc-400">focus: {whoami.focus}</p>
      <p class="text-zinc-400">passion: {whoami.passion}</p>
      <p class="mt-4"><span class="text-accent">andres@dev</span>:-$ <span class="animate-pulse">▌</span></p>
    </div>
    <p class="text-zinc-300 text-lg leading-relaxed">{excerpt}</p>
  </div>
</section>
