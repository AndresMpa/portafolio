---
// src/components/home/Skills.astro

import { skills } from "../../data/skills";
import { t } from "i18n:astro";

const groups = [
  { key: "languages", label: t("skills.languages") },
  { key: "backend", label: t("skills.backend") },
  { key: "frontend", label: t("skills.frontend") },
  { key: "ai", label: t("skills.ai") },
  { key: "infrastructure", label: t("skills.infrastructure") },
] as const;
---
<section class="py-24">
  <div class="max-w-7xl mx-auto px-6">
    <h3 class="text-sm uppercase text-accent mb-8">// 06_skills</h3>
    <div class="grid grid-cols-2 md:grid-cols-5 gap-8">
      {groups.map(({ key, label }) => (
        <div>
          <h4 class="text-xs uppercase text-zinc-500 mb-4">{label}</h4>
          <ul class="space-y-3">
            {skills[key].map((skill) => (
              <li>
                <div class="flex justify-between text-sm mb-1">
                  <span>{skill.name}</span>
                </div>
                <div class="h-1 bg-zinc-800 rounded">
                  <div class="h-1 bg-accent rounded" style={`width:${skill.level}%`}></div>
                </div>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>
