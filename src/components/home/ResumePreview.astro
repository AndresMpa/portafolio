---
// src/components/home/ResumePreview.astro

import { locale, t } from "i18n:astro";
---
<section class="py-24">
  <div class="max-w-7xl mx-auto px-6 flex flex-col md:flex-row items-center justify-between gap-8 border border-zinc-800 rounded-lg p-8">
    <div>
      <h4 class="font-bold text-lg">Andrés M. Prieto</h4>
      <p class="text-zinc-500 text-sm">AI Infrastructure & Fullstack Engineer</p>
    </div>
    <div class="md:text-right">
      <p class="text-zinc-300 max-w-md">
        {t("resume.description")}
      </p>
      <a href="/AndresMpa_CV.pdf" download class="text-accent text-sm mt-2 inline-block">
        {t("resume.download")} ↓
      </a>
    </div>
  </div>
</section>
