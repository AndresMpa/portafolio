---
// src/components/community/CommunityUpcoming.astro

import { t } from "i18n:astro";

interface Props {
  next: {
    title: string;
    place?: string;
    date: Date;
    href?: string;
  } | null;
  locale: string;
}

const { next, locale } = Astro.props;
---
<div class="border border-zinc-800 rounded-lg px-6 py-4 mb-10">
  {next ? (
    <a
      href={next.href ?? "#"}
      class="flex items-center gap-2 text-sm md:text-base hover:text-accent transition-colors"
    >
      <span class="text-accent font-semibold">{t("beyondCode.upcoming.label")}</span>
      <span class="font-medium">{next.title}</span>
      {next.place && (
        <span class="text-zinc-500">{t("beyondCode.upcoming.in")} {next.place}</span>
      )}
      <span class="text-zinc-500">{t("beyondCode.upcoming.in")} {next.place}</span>
      <span class="text-zinc-500">
        {t("beyondCode.upcoming.on")} {next.date.toLocaleDateString(locale, { year: "numeric", month: "long", day: "numeric" })}
      </span>
    </a>
  ) : (
    <p class="text-sm text-zinc-500">{t("beyondCode.upcoming.empty")}</p>
  )}
</div>
