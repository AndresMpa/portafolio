---
// src/components/home/Community.astro

import { t } from "i18n:astro";
import { getCommunity } from "../../lib/community";
import { talks } from "../../data/talks";

import ubuco from "../../assets/ubuco.png";
import forest from "../../assets/forest.png";
import flisol from "../../assets/flisol.png";

const iconMap: Record<string, ImageMetadata> = {
  "ubuntu-colombia": ubuco,
  forest: forest,
  flisol: flisol,
};

const lang = Astro.currentLocale ?? "en";
const entries = await getCommunity(lang);
---

<section id="open-source" class="py-4">
  <div class="max-w-7xl mx-auto px-6">
    <h3 class="text-sm uppercase text-accent mb-8">// 04 {t("community.title")}</h3>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
      {entries.map((entry) => (
        <article class="border border-zinc-800 p-6 rounded flex items-center">
          <img src={iconMap[entry.slug].src} alt={entry.organization} class="w-12 h-12" />
          <div class="ml-5">
            <h4 class="font-bold">{entry.company}</h4>
            <p class="text-accent text-sm">{entry.role}</p>
            <p class="text-zinc-500 text-xs">
              {entry.startDate}{entry.endDate ? ` — ${entry.endDate}` : ` — ${t("community.present")}`}
            </p>
          </div>
        </article>
      ))}
      <article class="border border-zinc-800 p-6 rounded">
        <h4 class="font-bold">{t("community.andMore")}</h4>
        <p class="text-zinc-400 text-sm">
          {t("community.andMoreDescription1")} — {talks.length} {t("community.andMoreDescription2")}
        </p>
      </article>
    </div>
  </div>
</section>
