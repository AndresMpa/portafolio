---
// src/components/community/CommunityBanner.astro

import { t, getLocale } from "i18n:astro";

import { getCommunity } from "../../lib/community";

import arch from "../../assets/arch.png";
import ubuco from "../../assets/ubuco.png";
import forest from "../../assets/forest.png";
import flisol from "../../assets/flisol.png";

import type { HomeComponentsProps } from "../../types"

import TermTitle from "../shared/TermTitle.astro"

const iconMap: Record<string, ImageMetadata> = {
  "ubuntu-colombia": ubuco,
  forest: forest,
  flisol: flisol,
  "arch-linux": arch,
};

const lang = getLocale();
const entries = await getCommunity(lang);

const { order, id } = Astro.props as HomeComponentsProps;
---

<section id={id} class="py-4">
  <div class="max-w-7xl mx-auto px-6">
    <h2 class="text-sm text-accent mb-8">
      <TermTitle order={order} title={t("community.title")} />
    </h2>
    <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
      {entries.map((entry) => (
        <article class="border border-zinc-800 p-6 rounded flex items-center">
          <img src={iconMap[entry.slug].src} alt={entry.company} class="w-12 h-12 shrink-0" />
          <div class="ml-5">
            <h3 class="font-bold">{entry.company}</h3>
            <p class="text-accent text-sm">{entry.role}</p>
            <p class="text-zinc-400 text-xs">
              {entry.startDate}{entry.endDate ? ` — ${entry.endDate}` : ` — ${t("community.present")}`}
            </p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
