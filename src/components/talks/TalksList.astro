---
// src/components/talks/TalksList.astro

import { t } from "i18n:astro";

import type { TalksListProps } from "../../types";

const { items, locale } = Astro.props as TalksListProps;
---

<div class="flex flex-col md:flex-row gap-3 mb-8">
  <input
    type="text"
    id="beyond-code-search"
    placeholder={t("beyondCode.search")}
    class="flex-1 bg-transparent border border-zinc-800 rounded-lg px-4 py-2 text-sm focus:outline-none focus:border-accent"
  />
  <div class="relative" id="beyond-code-filter-wrapper">
    <button
      type="button"
      id="beyond-code-filter-btn"
      class="w-full md:w-auto flex items-center justify-between gap-2 bg-transparent border border-zinc-800 rounded-lg pl-4 pr-3 py-2 text-sm focus:outline-none focus:border-accent"
    >
      <span id="beyond-code-filter-label">{t("beyondCode.filters.all")}</span>
      <svg class="w-4 h-4 text-zinc-400 transition-transform" id="beyond-code-filter-chevron" viewBox="0 0 20 20" fill="none" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 8l4 4 4-4" />
      </svg>
    </button>
    <ul id="beyond-code-filter-menu" class="hidden absolute z-10 mt-1 w-full min-w-max bg-zinc-950 border border-zinc-800 rounded-lg overflow-hidden text-sm">
      <li data-value="all" class="filter-option px-4 py-2 hover:bg-zinc-800 cursor-pointer">{t("beyondCode.filters.all")}</li>
      <li data-value="writing" class="filter-option px-4 py-2 hover:bg-zinc-800 cursor-pointer">{t("beyondCode.filters.writing")}</li>
      <li data-value="event" class="filter-option px-4 py-2 hover:bg-zinc-800 cursor-pointer">{t("beyondCode.filters.events")}</li>
    </ul>
  </div>
</div>

<div class="divide-y divide-zinc-800" id="beyond-code-list">
  {items.length === 0 ? (
    <p class="text-zinc-400 text-sm py-8">{t("beyondCode.empty")}</p>
  ) : (
    items.map((item) => (
      <a href={item.href} data-type={item.type} data-title={item.title.toLowerCase()} class="update-item flex flex-col md:flex-row md:items-center md:justify-between gap-2 py-5 group">
        <div class="flex flex-col md:flex-row md:items-center gap-1 md:gap-6">
          <span class="text-zinc-400 text-xs md:w-32">{item.date.toLocaleDateString(locale)}</span>
          <span class="text-accent text-xs uppercase md:w-32">
            {item.type === "writing" ? t("beyondCode.filters.writing") : t("beyondCode.filters.events")}
          </span>
          <span class="font-medium group-hover:text-accent transition-colors">{item.title}</span>
        </div>
        <span class="text-accent self-end md:self-auto group-hover:translate-x-1 transition-transform">→</span>
      </a>
    ))
  )}
</div>

<script>
  const search = document.getElementById("beyond-code-search") as HTMLInputElement;
  const filterBtn = document.getElementById("beyond-code-filter-btn") as HTMLButtonElement;
  const filterMenu = document.getElementById("beyond-code-filter-menu") as HTMLUListElement;
  const filterLabel = document.getElementById("beyond-code-filter-label") as HTMLSpanElement;
  const filterChevron = document.getElementById("beyond-code-filter-chevron") as unknown as SVGElement;
  const filterWrapper = document.getElementById("beyond-code-filter-wrapper") as HTMLDivElement;
  const options = document.querySelectorAll<HTMLLIElement>(".filter-option");
  const items = document.querySelectorAll<HTMLElement>(".update-item");
  let currentFilter = "all";

  function applyFilters() {
    const query = search.value.trim().toLowerCase();
    items.forEach((item) => {
      const matchesType = currentFilter === "all" || item.dataset.type === currentFilter;
      const matchesQuery = !query || item.dataset.title?.includes(query);
      item.classList.toggle("hidden", !(matchesType && matchesQuery));
    });
  }
  function toggleMenu(open?: boolean) {
    const shouldOpen = open ?? filterMenu.classList.contains("hidden");
    filterMenu.classList.toggle("hidden", !shouldOpen);
    filterChevron.classList.toggle("rotate-180", shouldOpen);
  }
  filterBtn.addEventListener("click", () => toggleMenu());
  options.forEach((option) => {
    option.addEventListener("click", () => {
      currentFilter = option.dataset.value ?? "all";
      filterLabel.textContent = option.textContent;
      toggleMenu(false);
      applyFilters();
    });
  });
  document.addEventListener("click", (e) => {
    if (!filterWrapper.contains(e.target as Node)) toggleMenu(false);
  });
  search.addEventListener("input", applyFilters);
</script>
