---
// src/components/seo/ProjectsJsonLd.astro

import { getCollection } from "astro:content";

import { site } from "../../data/site";

const projects = await getCollection("projects");
---

<script
  is:inline
  type="application/ld+json"
  set:html={JSON.stringify({
    "@context": "https://schema.org",

    "@graph": [
      {
        "@type": "ItemList",

        "@id": `${site.url}/projects`,

        name: "Software Engineering Projects",

        itemListElement: projects.map((project, index) => ({
          "@type": "ListItem",

          position: index + 1,

          item: {
            "@id":
              `${site.url}/${project.data.locale}/projects/${project.data.slug}#software`
          }
        }))
      },

      ...projects.map(project => ({
        "@type": "SoftwareSourceCode",

        "@id":
          `${site.url}/${project.data.locale}/projects/${project.data.slug}#software`,

        url:
          `${site.url}/${project.data.locale}/projects/${project.data.slug}`,

        name: project.data.title,

        description: project.data.description,

        abstract:
          project.data.intent?.join(". "),

        keywords: project.data.keywords,

        codeRepository: project.data.repository,

        creativeWorkStatus: project.data.status,

        inLanguage: project.data.locale,

        about: project.data.aiTopics.map(topic => ({
          "@type": "Thing",
          name: topic,
        })),

        teaches: project.data.skills.map(skill => ({
          "@type": "DefinedTerm",
          name: skill,
        })),

        audience: project.data.expertise.map(exp => ({
          "@type": "Audience",
          audienceType: exp,
        })),
      }))
    ]
  })}
/>
