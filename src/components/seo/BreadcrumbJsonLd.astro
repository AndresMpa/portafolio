---
interface Crumb {
  name: string;
  url: string;
}

interface Props {
  items: Crumb[];
}

const { items } = Astro.props;
---

<script
  is:inline
  type="application/ld+json"
  set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: items.map((item, index) => ({
      "@type": "ListItem",
      position: index + 1,
      name: item.name,
      item: item.url,
    })),
  })}
/>
