---
// src/components/seo/BreadcrumbJsonLd.astro

import type { BreadcrumbJsonLdProps } from "../../types";

const { items } = Astro.props as BreadcrumbJsonLdProps;
---

<script
  is:inline
  type="application/ld+json"
  set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: items.map((item, index) => ({
      "@type": "ListItem",
      position: index + 1,
      name: item.name,
      item: item.url,
    })),
  })}
/>
