---
// src/components/home/HeroMetrics.astro

import { t } from "i18n:astro";

import { stats } from "../../data/person";
---

<div class="grid grid-cols-2 md:grid-cols-4 mt-8 md:border-t md:border-zinc-800">
  <div class="p-8 text-center border-r border-b border-zinc-800 md:border-b-0">
    <p class="text-2xl font-bold text-accent">{stats.yearsExperience}+</p>
    <p class="text-xs uppercase text-zinc-400 mt-1">{t("hero.metrics.experience")}</p>
  </div>
  <div class="p-8 text-center border-b border-zinc-800 md:border-b-0 md:border-r">
    <p class="text-2xl font-bold text-accent">{stats.projectsCount}+</p>
    <p class="text-xs uppercase text-zinc-400 mt-1">{t("hero.metrics.projects")}</p>
  </div>
  <div class="p-8 text-center border-r border-zinc-800">
    <p class="text-2xl font-bold text-accent">{t("hero.metrics.openSource")}</p>
    <p class="text-xs uppercase text-zinc-400 mt-1">{t("hero.metrics.contributor")}</p>
  </div>
  <div class="p-8 text-center">
    <p class="text-2xl font-bold text-accent">{t("hero.metrics.basedIn")}</p>
    <p class="text-xs uppercase text-zinc-400 mt-1">{stats.location}</p>
  </div>
</div>
