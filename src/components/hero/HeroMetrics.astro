---
// src/components/home/HeroMetrics.astro

import { t } from "i18n:astro";

import { stats } from "../../data/person";
---

<div class="border-t border-zinc-800 grid grid-cols-2 md:grid-cols-4 mt-8">
  <div class="p-8 border-r border-zinc-800 text-center">
    <p class="text-2xl font-bold text-accent">{stats.yearsExperience}+</p>
    <p class="text-xs uppercase text-zinc-500 mt-1">{t("hero.metrics.experience")}</p>
  </div>
  <div class="p-8 border-r border-zinc-800 text-center">
    <p class="text-2xl font-bold text-accent">{stats.projectsCount}+</p>
    <p class="text-xs uppercase text-zinc-500 mt-1">{t("hero.metrics.projects")}</p>
  </div>
  <div class="p-8 border-r border-zinc-800 text-center">
    <p class="text-2xl font-bold text-accent">{t("hero.metrics.openSource")}</p>
    <p class="text-xs uppercase text-zinc-500 mt-1">{t("hero.metrics.contributor")}</p>
  </div>
  <div class="p-8 text-center">
    <p class="text-2xl font-bold text-accent">{t("hero.metrics.basedIn")}</p>
    <p class="text-xs uppercase text-zinc-500 mt-1">{stats.location}</p>
  </div>
</div>
