---
// src/components/layout/Navigation.astro

import { t } from "i18n:astro";

const navItems = [
  { key: "home", href: "/" },
  { key: "projects", href: "/projects" },
  { key: "experience", href: "/experience" },
  { key: "writing", href: "/writing" },
  { key: "community", href: "/community" },
  { key: "about", href: "/about" },
  { key: "resume", href: "/resume" },
];

const currentPath = Astro.url.pathname;
---

<nav class="hidden md:flex gap-8 text-xs uppercase tracking-wider mt-0">
  {navItems.map((item) => {
    const isActive = item.href === "/" ? currentPath === "/" : currentPath.startsWith(item.href);
    return (
      <a
        href={item.href}
        class={`pb-1 border-b-2 ${isActive ? "border-accent text-accent" : "border-transparent text-zinc-400 hover:text-zinc-200"}`}
      >
        {t(`nav.${item.key}`)}
      </a>
    );
  })}
</nav>
