---
// src/components/layout/Navigation.astro

import { t, getLocale } from "i18n:astro";

const locale = getLocale();
const defaultLocale = "en";

const navItems = [
  { key: "home", href: "/" },
  { key: "projects", href: "/projects" },
  { key: "experience", href: "/experience" },
  { key: "beyondCode", href: "/beyond-code" },
  { key: "about", href: "/about" },
  { key: "resume", href: "/resume" },
];

const currentPath = Astro.url.pathname;

function localize(path: string) {
  if (locale === defaultLocale) return path;
  return path === "/" ? `/${locale}` : `/${locale}${path}`;
}
---

<nav class="hidden md:flex gap-8 text-xs uppercase tracking-wider mt-0">
  {navItems.map((item) => {
    const href = localize(item.href);
    const isActive =
      item.href === "/"
        ? currentPath === "/" || currentPath === `/${locale}` || currentPath === `/${locale}/`
        : currentPath.startsWith(item.href) || currentPath.startsWith(`/${locale}${item.href}`);
    return (
      <a
        href={href}
        class={`pb-1 border-b-2 ${
          isActive
            ? "border-accent text-accent"
            : "border-transparent text-zinc-400 hover:text-zinc-200"
        }`}
      >
        {t(`nav.${item.key}`)}
      </a>
    );
  })}
</nav>
