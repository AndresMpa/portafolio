---
// src/components/layout/Navigation.astro
import { t, getLocale } from "i18n:astro";
import { localizeHref } from "../../lib/utils";

interface Props {
  lines?: number;
  variant?: "desktop" | "mobile";
}

const { lines = 1, variant = "desktop" } = Astro.props as Props;

const locale = getLocale();
const navItems = [
  { key: "home", href: "/" },
  { key: "projects", href: "/projects" },
  { key: "education", href: "/education" },
  { key: "experience", href: "/experience" },
  { key: "beyondCode", href: "/beyond-code" },
  { key: "about", href: "/about" },
  { key: "resume", href: "/resume" },
  { key: "faq", href: "/faq" },
];

const currentPath = Astro.url.pathname;

function isItemActive(href: string) {
  return href === "/"
    ? currentPath === `/${locale}` || currentPath === `/${locale}/`
    : currentPath.startsWith(`/${locale}${href}`);
}

const itemsPerLine = Math.ceil(navItems.length / lines);
---

{variant === "desktop" ? (
  <nav
    class="hidden md:grid gap-x-8 gap-y-3 text-xs uppercase tracking-wider mt-0"
    style={`grid-template-columns: repeat(${itemsPerLine}, max-content);`}
  >
    {navItems.map((item) => {
      const href = localizeHref(item.href, locale);
      const isActive = isItemActive(item.href);
      return (
        <a
          href={href}
          class={`pb-1 border-b-2 ${
            isActive
              ? "border-accent text-accent"
              : "border-transparent text-zinc-400 hover:text-zinc-200"
          }`}
        >
          {t(`nav.${item.key}` as any)}
        </a>
      );
    })}
  </nav>
) : (
  <nav class="flex flex-col gap-6 text-sm uppercase tracking-wider">
    {navItems.map((item) => {
      const href = localizeHref(item.href, locale);
      const isActive = isItemActive(item.href);
      return (
        <a
          href={href}
          class={`mobile-nav-link pb-1 border-b w-fit ${
            isActive
              ? "border-accent text-accent"
              : "border-transparent text-zinc-400 hover:text-zinc-200"
          }`}
        >
          {t(`nav.${item.key}` as any)}
        </a>
      );
    })}
  </nav>
)}
