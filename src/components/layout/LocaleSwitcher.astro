---
// src/components/layout/LocaleSwitcher.astro

import { t, getLocale, getSwitcherData } from "i18n:astro";
import { Image } from "astro:assets";

import translate from "../../assets/translate.svg";

const locale = getLocale();
const data = getSwitcherData();
---

<div class="relative mx-3 mb-1" id="locale-switcher">
  <button
    id="locale-btn"
    class="flex h-8 w-8 items-center justify-center rounded-full bg-accent transition hover:scale-105"
    aria-label={t("selectLanguage")}
    aria-expanded="false"
  >
    <Image src={translate} alt="Translate options" loading="eager" />
  </button>

  <div
    id="locale-menu"
    class="absolute right-0 top-9 origin-top scale-y-0 opacity-0 pointer-events-none overflow-hidden rounded-lg bg-accent shadow-lg transition-all duration-200 ease-out"
  >
    {
      data.map((item) => (
        <a
          href={item.href}
          class={`block px-4 py-2 text-center text-black hover:bg-white/20 ${
            item.locale === locale ? "font-bold" : ""
          }`}
        >
          {item.locale}
        </a>
      ))
    }
  </div>
</div>

<script>
  const switcher = document.getElementById("locale-switcher");
  const button = document.getElementById("locale-btn");
  const menu = document.getElementById("locale-menu");

  if (!switcher || !button || !menu) throw new Error("LocaleSwitcher: missing required elements");

  button.addEventListener("click", () => {
    const open = menu.classList.toggle("open");

    menu.classList.toggle("scale-y-0", !open);
    menu.classList.toggle("opacity-0", !open);
    menu.classList.toggle("pointer-events-none", !open);

    menu.classList.toggle("scale-y-100", open);
    menu.classList.toggle("opacity-100", open);

+   button.setAttribute("aria-expanded", String(open));
  });

  document.addEventListener("click", (e) => {
    if (!switcher.contains(e.target as Node)) {
      menu.classList.add("scale-y-0", "opacity-0", "pointer-events-none");
      menu.classList.remove("scale-y-100", "opacity-100");
      button.setAttribute("aria-expanded", "false");
    }
  });
</script>
