---
import icon from "../assets/icon.svg";
import cv from "../assets/AndresMpa_CV.pdf";
import download from "../assets/download.svg";

import LocaleSwitcher from "./LocaleSwitcher.astro";
---

<nav id="home" class="flex justify-between p-4">
  <img src={icon.src} alt={"Menu icon"} width={45} class="ml-2" /><img />

  <div class="flex items-center">
    <LocaleSwitcher />
    <a
      href={cv}
      download="AndresMpa_CV.pdf"
      class="p-2 mr-2 rounded-full bg-accent hover:bg-accent active:bg-accent focus:outline-none focus:ring focus:ring-accent flex items-center justify-center"
    >
      <img src={download.src} alt="Download CV" width={15} class="white-svg" />
    </a>
  </div>
</nav>

<style>
  .white-svg {
    filter: brightness(0) invert(1);
    &:hover {
      filter: brightness(1.5) invert(1) drop-shadow(0 0 5px #ffffff);
    }
  }
</style>
