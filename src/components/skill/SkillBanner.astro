---
// src/components/home/Skills.astro

import { t } from "i18n:astro";

import { skills } from "../../data/skills";

import type { HomeComponentsProps } from "../../types"

import TermTitle from "../shared/TermTitle.astro"

const icons = import.meta.glob<{ default: ImageMetadata }>(
  "../../assets/skills/*.svg",
  { eager: true }
);

function resolveIcon(name: string): ImageMetadata | undefined {
  return icons[`../../assets/skills/${name}.svg`]?.default;
}

const groups = [
  { key: "languages", label: t("skills.languages") },
  { key: "backend", label: t("skills.backend") },
  { key: "frontend", label: t("skills.frontend") },
  { key: "ai", label: t("skills.ai") },
  { key: "infrastructure", label: t("skills.infrastructure") },
] as const;

const { order, id } = Astro.props as HomeComponentsProps;
---

<section id={id} class="py-4">
  <div class="max-w-7xl mx-auto px-6">
    <h2 class="text-sm text-accent mb-8">
      <TermTitle order={order} title={t("skills.title")} />
    </h2>
    <div class="grid grid-cols-2 md:grid-cols-5 gap-8">
      {groups.map(({ key, label }) => (
        <div>
          <h3 class="text-xs uppercase text-zinc-500 mb-4">{label}</h3>
          <div class="grid grid-cols-2 gap-4">
            {skills[key].map((skill) => {
              const icon = resolveIcon(skill.icon);
              return (
                <div class="flex flex-col items-center text-center gap-2">
                  {icon ? (
                    <img src={icon.src} alt={skill.name} class="w-9 h-9" />
                  ) : (
                    <div class="w-9 h-9 rounded bg-zinc-800 flex items-center justify-center text-accent text-xs">
                      {skill.name.slice(0, 2)}
                    </div>
                  )}
                  <span class="text-xs text-zinc-400">{skill.name}</span>
                </div>
              );
            })}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
