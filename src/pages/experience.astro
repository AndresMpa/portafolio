---
// src/pages/experience/index.astro

import { t } from "i18n:astro";

import Layout from "../layouts/Layout.astro";

import { getExperience } from "../lib/experience";
import { person } from "../data/person";

const lang = Astro.currentLocale ?? "en";
const entries = await getExperience(lang);
const title = `${person.name} | ${t("experience.title")}`;

const current = entries.filter((e) => e.endDate === null);
const past = entries.filter((e) => e.endDate !== null);
---
<Layout title={title}>
  <section class="max-w-7xl mx-auto px-6 py-24">
    <h1 class="text-4xl md:text-5xl font-black leading-tight mb-12">
      {t("experience.title")}
    </h1>

    {current.length > 0 && (
      <div class="mb-16">
        <h2 class="text-sm text-accent mb-6">{t("experience.current")}</h2>
        <div class="grid md:grid-cols-2 gap-6">
          {current.map((item) => (
            <div class="border border-zinc-800 rounded-lg p-6">
              <p class="text-accent text-sm">
                {item.startDate.slice(0, 4)} — {t("experience.present")}
              </p>
              <h4 class="font-bold text-lg mt-1">{item.role}</h4>
              <p class="text-zinc-500">{item.company}</p>
              {item.description && <p class="text-zinc-400 mt-2">{item.description}</p>}
              {item.stack?.length > 0 && (
                <div class="flex gap-2 mt-3 flex-wrap">
                  {item.stack.map((tech) => (
                    <span class="bg-accent/20 text-accent text-xs px-2 py-1 rounded-full">{tech}</span>
                  ))}
                </div>
              )}
            </div>
          ))}
        </div>
      </div>
    )}

    <div class="relative border-l border-zinc-800 pl-8 space-y-10">
      {past.map((item) => (
        <div class="relative">
          <span class="absolute -left-[2.35rem] w-3 h-3 bg-accent rounded-full"></span>
          <p class="text-accent text-sm">
            {item.startDate.slice(0, 4)} — {item.endDate.slice(0, 4)}
          </p>
          <h4 class="font-bold text-lg">{item.role}</h4>
          <p class="text-zinc-500">{item.company}</p>
          {item.description && <p class="text-zinc-400 mt-2 max-w-2xl">{item.description}</p>}
          {item.stack?.length > 0 && (
            <div class="flex gap-2 mt-3 flex-wrap">
              {item.stack.map((tech) => (
                <span class="bg-accent/20 text-accent text-xs px-2 py-1 rounded-full">{tech}</span>
              ))}
            </div>
          )}
        </div>
      ))}
    </div>
  </section>
</Layout>
