---
// src/pages/resume.astro

import { t } from "i18n:astro";

import Layout from "../layouts/Layout.astro";

import BreadcrumbJsonLd from "../components/seo/BreadcrumbJsonLd.astro";

import { site } from "../data/site";
import { person } from "../data/person";

const cv = "/AndresMpa_CV.pdf";

const title = `${person.name} | ${t("resume.title")}`;
---

<Layout title={title} description={t("resume.description")}>
  <BreadcrumbJsonLd
    items={[
      { name: "Home", url: site.url },
      { name: "Resume", url: `${site.url}/resume` },
    ]}
  />
  <section class="max-w-5xl mx-auto px-6 py-6 pb-24">
    <div class="flex justify-between items-center mb-8">
      <h1 class="text-4xl md:text-5xl font-black leading-tight">
        {t("resume.title")}
      </h1>
      <a
        href={cv}
        download="AndresMpa_CV.pdf"
        class="p-2 mr-2 rounded-full bg-accent hover:bg-accent active:bg-accent focus:outline-none focus:ring focus:ring-accent flex items-center justify-center"
      >
        <span class="md:ml-1 font-bold">
          ↓<span class="hidden md:inline"> {t("hero.actions.downloadResume")}</span>
        </span>
      </a>
    </div>
    <div class="border border-zinc-800 rounded-lg overflow-hidden bg-black/40" style="height: 85vh;">
      <object data={cv} type="application/pdf" width="100%" height="100%">
        <embed src={cv} type="application/pdf" width="100%" height="100%" />
        <div class="flex items-center justify-center h-full p-6">
          <p class="text-zinc-400 text-center">
            {t("resume.fallback")} <br/><br/>
            <a href={cv} download="AndresMpa_CV.pdf" class="text-accent hover:underline">
              {t("resume.download")}
            </a>
          </p>
        </div>
      </object>
    </div>
  </section>
</Layout>
