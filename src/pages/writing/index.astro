---
// src/pages/writing/index.astro
import Layout from "../../layouts/Layout.astro";
import { getAllWriting } from "../../lib/writing";
import { person } from "../../data/person";
import { t } from "i18n:astro";

const lang = Astro.currentLocale ?? "en";
const posts = await getAllWriting(lang);
const title = `${person.name} | ${t("writing.title")}`;
---

<Layout title={title}>
  <section class="max-w-7xl mx-auto px-6 py-6 pb-24">
    <h1 class="text-4xl md:text-5xl font-black leading-tight mb-12">
      {t("writing.title")}
    </h1>
    {posts.length === 0 ? (
      <p class="text-zinc-600 text-sm">No posts yet.</p>
    ) : (
      <div class="divide-y divide-zinc-800">
        {posts.map((post) => (
          <a
            href={`/writing/${post.data.locale}/${post.data.slug}`}
            class="flex flex-col md:flex-row md:items-center md:justify-between gap-2 md:gap-6 py-5 px-2 -mx-2 rounded-lg group hover:bg-zinc-900/50 transition-colors"
          >
            <div class="flex flex-col md:flex-row md:items-center gap-1 md:gap-6">
              <div class="flex items-center gap-3 md:contents">
                <span class="text-zinc-500 text-xs md:text-sm md:w-32">
                  {post.data.date.toLocaleDateString(lang)}
                </span>
                <span class="text-accent text-xs uppercase md:w-32">{post.data.kind}</span>
              </div>
              <span class="text-base font-medium group-hover:text-accent transition-colors">
                {post.data.title}
              </span>
            </div>
            <span class="text-accent self-end md:self-auto group-hover:translate-x-1 transition-transform">→</span>
          </a>
        ))}
      </div>
    )}
  </section>
</Layout>
