---
// src/pages/writing/index.astro
import Layout from "../../layouts/Layout.astro";
import { getAllWriting } from "../../lib/writing";
import { person } from "../../data/person";
import { t } from "i18n:astro";

const lang = Astro.currentLocale ?? "en";
const posts = await getAllWriting(lang);
const title = `${person.name} | ${t("writing.title")}`;
---
<Layout title={title}>
  <section class="max-w-7xl mx-auto px-6 py-24">
    <h1 class="text-4xl md:text-5xl font-black leading-tight mb-12">
      {t("writing.title")}
    </h1>
    {posts.length === 0 ? (
      <p class="text-zinc-600 text-sm">No posts yet.</p>
    ) : (
      <div class="divide-y divide-zinc-800">
        {posts.map((post) => (
          <a
            href={`/writing/${post.data.locale}/${post.data.slug}`}
            class="flex justify-between items-center py-4 group"
          >
            <div class="flex gap-6 items-center">
              <span class="text-zinc-500 text-sm w-32">
                {post.data.date.toLocaleDateString(lang)}
              </span>
              <span class="text-accent text-xs uppercase w-32">{post.data.kind}</span>
              <span class="group-hover:text-accent">{post.data.title}</span>
            </div>
            <span class="text-accent">→</span>
          </a>
        ))}
      </div>
    )}
  </section>
</Layout>
