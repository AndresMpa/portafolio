---
// src/pages/about.astro

import { getCollection, render } from "astro:content";
import { getLocale } from "i18n:astro";

import BreadcrumbJsonLd from "../components/seo/BreadcrumbJsonLd.astro";

import Layout from "../layouts/Layout.astro";

import { site } from "../data/site";

const locale = getLocale();
const page = (await getCollection("about")).find(
  (entry) => entry.data.locale === locale
);

if (!page) {
  throw new Error(`No about page for locale "${locale}"`);
}

const { Content } = await render(page);
---

<Layout title={page.data.title} description={page.data.description}>
  <BreadcrumbJsonLd
    items={[
      { name: "Home", url: site.url },
      { name: "About", url: `${site.url}/about` },
    ]}
  />
  <article class="max-w-3xl mx-auto px-6 py-24 prose prose-invert">
    <Content />
  </article>
</Layout>
