---
import I18nClient from "@astrolicious/i18n/components/I18nClient.astro"
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title: string;
}

const { title } = Astro.props;
const ogImage = "https://andresmpa.netlify.app/og-image.png";
---

<!doctype html>
<html lang="en">
  <head>
    <!--General metadata-->
    <meta charset="UTF-8" />
    <meta
      name="description"
      content="Senior software engineer — AI infrastructure and fullstack development on GNU/Linux."
    />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>

    <!--Canonical data-->
    <link rel="me" href="https://github.com/AndresMpa">
    <link rel="me" href="https://www.linkedin.com/in/andresmpa/">

    <!--Favicon stuff-->
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <meta name="theme-color" content="#09090d" />

    <!-- Open Graph Meta Tags -->
    <meta
      property="og:title"
      content="AndresMpa - Senior Engineer, AI Infrastructure & Fullstack"
    />
    <meta property="og:site_name" content="AndresMpa's Portfolio" />
    <meta property="og:url" content="https://andresmpa.netlify.app/" />
    <meta
      property="og:description"
      content="Senior software engineer — AI infrastructure and fullstack development on GNU/Linux."
    />
    <meta property="og:type" content="profile" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter Card Meta Tags -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta
      name="twitter:title"
      content="AndresMpa - Senior Engineer, AI Infrastructure & Fullstack"
    />
    <meta
      name="twitter:description"
      content="Senior software engineer — AI infrastructure and fullstack development on GNU/Linux."
    />
    <meta name="twitter:url" content="https://andresmpa.netlify.app/" />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:site" content="@AndresMpa" />
    <meta name="twitter:creator" content="@AndresMpa" />

    <!-- Structured data for search engines and AI agents -->
    <script is:inline type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "Andrés M. Prieto",
      "url": "https://andresmpa.netlify.app/",
      "jobTitle": "Senior Software Engineer",
      "description": "Senior software engineer — AI infrastructure and fullstack development on GNU/Linux.",
      "sameAs": [
        "https://github.com/AndresMpa",
        "https://www.linkedin.com/in/andresmpa/",
        "https://stackoverflow.com/users/15334340",
        "https://andresprieto-25116.medium.com/"
      ]
    })} />

    <I18nClient />
  </head>
  <body class="bg-background text-text">
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>

<style is:global>
</style>
