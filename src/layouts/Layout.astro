---
// src/layouts/Layouts.astro

import I18nClient from "@astrolicious/i18n/components/I18nClient.astro";

import Header from "../components/layout/Header.astro";
import Footer from "../components/layout/Footer.astro";
import SEO from "../components/seo/SEO.astro";

interface Props {
  title: string;
  description?: string;
  image?: string;
}

const {
  title,
  description = "Senior software engineer — AI infrastructure and fullstack development on GNU/Linux.",
  image = "https://andresmpa.netlify.app/og-image.png",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <SEO
      title={title}
      description={description}
      image={image}
    />

    <I18nClient />
  </head>

  <body class="bg-background text-text">
    <Header />

    <main>
      <slot />
    </main>

    <Footer />
  </body>
</html>
