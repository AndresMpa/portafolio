---
// src/routes/faq.astro

import { getLocale } from "i18n:astro";
import { getCollection } from "astro:content";

import Layout from "../layouts/Layout.astro";

import BreadcrumbJsonLd from "../components/seo/BreadcrumbJsonLd.astro";
import FAQJsonLd from "../components/seo/FAQJsonLd.astro";

import { site } from "../data/site";

const locale = getLocale();
const page = (await getCollection("faq")).find(
  (entry) => entry.data.locale === locale
);

if (!page) {
  throw new Error(`No FAQ page for locale "${locale}"`);
}

const { title, description, items } = page.data;
---

<Layout title={title} description={description}>
  <BreadcrumbJsonLd
    items={[
      { name: "Home", url: site.url },
      { name: title, url: `${site.url}/faq` },
    ]}
  />
  <FAQJsonLd items={items} />

  <section class="max-w-7xl mx-auto px-6 py-6 pb-24">
    <h1 class="text-4xl md:text-5xl font-black leading-tight mb-8">
      {title}
    </h1>

    <dl class="flex flex-col gap-6">
      {items.map((item) => (
        <div class="border border-zinc-800 rounded-lg p-6">
          <dt class="font-semibold text-accent mb-2">{item.question}</dt>
          <dd class="text-zinc-400 leading-relaxed">{item.answer}</dd>
        </div>
      ))}
    </dl>
  </section>
</Layout>
