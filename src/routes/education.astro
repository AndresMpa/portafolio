---
// src/routes/education.astro

import { t, getLocale } from "i18n:astro";

import Layout from "../layouts/Layout.astro";

import BreadcrumbJsonLd from "../components/seo/BreadcrumbJsonLd.astro";

import { getEducation } from "../lib/education";

import { person } from "../data/person";
import { site } from "../data/site";

const lang = getLocale();
const entries = await getEducation(lang);

const title = `${person.name} | ${t("education.title")}`;
---

<Layout title={title}>
  <BreadcrumbJsonLd
    items={[
      { name: "Home", url: site.url },
      { name: "Education", url: `${site.url}/education` },
    ]}
  />
  <section class="max-w-7xl mx-auto px-6 py-6 pb-24">
    <h1 class="text-4xl md:text-5xl font-black leading-tight mb-12">
      {t("education.title")}
    </h1>
    <div class="space-y-8">
      {entries.map((item) => (
        <div class="border-b border-zinc-800 pb-6">
          <p class="text-accent text-sm">
            {item.year}
          </p>
          <h3 class="font-bold text-lg">{item.degree}</h3>
          <p class="text-zinc-400">{item.institution}</p>
        </div>
      ))}
    </div>
  </section>
</Layout>
