---
// src/routes/projects/[...slug].astro

import { getCollection, render } from "astro:content";
import { t, getLocalePlaceholder } from "i18n:astro";

import BreadcrumbJsonLd from "../../components/seo/BreadcrumbJsonLd.astro";

import Layout from "../../layouts/Layout.astro";

import { site } from "../../data/site";

export async function getStaticPaths() {
  const locale = getLocalePlaceholder();
  const projects = await getCollection(
    "projects",
    (project) => project.data.locale === locale
  );
  return projects.map((project) => ({
    params: { slug: project.data.slug },
    props: { project },
  }));
}

function repoName(url: string) {
  return url.replace(/\/$/, "").split("/").pop() ?? url;
}

const { project } = Astro.props;
const { Content } = await render(project);

const isGitHub = (url: string) => new URL(url).hostname.includes("github.com");

const githubRepos = project.data.repository.filter(isGitHub);
const deployments = project.data.repository.filter((url) => !isGitHub(url));
---

<Layout
  title={project.data.title}
  description={project.data.description}
  keywords={project.data.keywords}
  project={project}
>
  <BreadcrumbJsonLd
    items={[
      { name: "Home", url: `${site.url}/${project.data.locale}` },
      { name: "Projects", url: `${site.url}/${project.data.locale}/projects` },
      {
        name: project.data.title,
        url: `${site.url}/${project.data.locale}/projects/${project.data.slug}`,
      },
    ]}
  />

  <div class="mx-auto max-w-6xl px-4 py-10 grid grid-cols-1 lg:grid-cols-[1fr_280px] gap-12">
    <div class="min-w-0">
      {
        project.data.featured && (
          <span class="inline-block rounded-full border border-accent/40 bg-accent/10 px-3 py-1 text-xs tracking-wider text-accent mb-4">
            { t("projects.detail.specialLabel") }
          </span>
        )
      }

      <article class="numbered-headings prose prose-invert max-w-none">
        <Content />
      </article>

      {
        project.data.aiTopics.length > 0 && (
          <section class="mt-16">
            <h2 class="text-sm font-semibold uppercase tracking-wider text-text/60 mb-4">
              { t("projects.detail.knowledgeAreas") }
            </h2>
            <div class="flex flex-wrap gap-2">
              {project.data.aiTopics.map((topic) => (
                <span class="rounded-full border border-accent/30 bg-accent/10 px-3 py-1 text-xs text-text">
                  {topic}
                </span>
              ))}
            </div>
          </section>
        )
      }
    </div>

    <aside>
      {
        project.data.repository.length > 0 && (
          <div class="rounded-lg border border-white/10 bg-accent/5 p-5 lg:sticky lg:top-24">
            {githubRepos.length > 0 && (
              <>
              <h2 class="text-sm font-semibold text-text mb-4">
                { t("projects.detail.repositories") }
              </h2>
                <ul class="space-y-3">
                  {githubRepos.map((repo) => (
                    <li>
                      <a
                        href={repo}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="block text-sm text-text/90 hover:text-accent transition truncate"
                      >
                        {repoName(repo)}
                      </a>
                    </li>
                  ))}
                </ul>
              </>
            )}

            {deployments.length > 0 && (
              <>
                <hr class="my-5 border-white/10" />
                <h2 class="text-sm font-semibold text-text mb-4">
                  { t("projects.detail.deployments") }
                </h2>
                <ul class="space-y-3">
                  {deployments.map((url) => (
                    <li>
                      <a
                        href={url}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="block text-sm text-text/90 hover:text-accent transition truncate"
                      >
                        {repoName(url)}
                      </a>
                    </li>
                  ))}
                </ul>
              </>
            )}
          </div>
        )
      }
    </aside>
  </div>

  {
    project.data.skills.length > 0 && (
      <section class="border-t border-white/10 mt-4 py-10">
        <div class="mx-auto max-w-6xl px-4">
          <h2 class="text-sm uppercase tracking-wider text-text/60 mb-4">
            { t("projects.detail.skillsDemonstrated") }
          </h2>
          <div class="flex flex-wrap gap-x-4 gap-y-2 font-mono text-sm text-accent">
            {project.data.skills.map((skill) => (
              <span>#{skill.replace(/\s+/g, "")}</span>
            ))}
          </div>
        </div>
      </section>
    )
  }
</Layout>

<style>
  .numbered-headings {
    counter-reset: section;
  }
  .numbered-headings :global(h2) {
    counter-increment: section;
  }
  .numbered-headings :global(h2)::before {
    content: counter(section) ". ";
  }
</style>
