---
// src/pages/community.astro

import { getLocale } from "i18n:astro";
import { getCollection, render } from "astro:content";

import BreadcrumbJsonLd from "../components/seo/BreadcrumbJsonLd.astro";

import Layout from "../layouts/Layout.astro";

import { site } from "../data/site";

const locale = getLocale();
const page = (await getCollection("community")).find(
  (entry) => entry.data.locale === locale
);

if (!page) {
  throw new Error(`No community page for locale "${locale}"`);
}

const { Content } = await render(page);
---

<Layout title={page.data.title} description={page.data.description}>
  <BreadcrumbJsonLd
    items={[
      { name: "Home", url: site.url },
      { name: "Community", url: `${site.url}/community` },
    ]}
  />
  <article class="max-w-3xl mx-auto px-6 py-4 prose prose-invert">
    <Content />
  </article>
</Layout>
