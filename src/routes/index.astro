---
// src/routes/index.astro

import { t } from "i18n:astro";
import Layout from "../layouts/Layout.astro";
import Hero from "../components/hero/Hero.astro";
import ExperienceTimeline from "../components/experience/ExperienceTimeline.astro";
import EducationSummary from "../components/education/EducationSummary.astro";
import ProjectFeatured from "../components/project/ProjectFeatured.astro";
import CommunityBanner from "../components/community/CommunityBanner.astro";
import WritingLatest from "../components/writing/WritingLatest.astro";
import SkillBanner from "../components/skill/SkillBanner.astro";

const title = `${t("title")}`;
---
<Layout title={title}>
  <Hero />
  <ProjectFeatured order={1} id="projects" />
  <ExperienceTimeline order={2} id="experience" />
  <EducationSummary order={3} id="education" />
  <CommunityBanner order={4} id="community" />
  <WritingLatest order={5} id="writing" />
  <SkillBanner order={6} id="skills" />
</Layout>
