---
// src/routes/index.astro

import { t } from "i18n:astro";
import Layout from "../layouts/Layout.astro";
import Hero from "../components/hero/Hero.astro";
import Experience from "../components/home/Experience.astro";
import FeaturedProjects from "../components/home/FeaturedProjects.astro";
import Community from "../components/home/Community.astro";
import Skills from "../components/home/Skills.astro";
import Writing from "../components/home/Writing.astro";
import AboutPreview from "../components/home/AboutPreview.astro";
import ResumePreview from "../components/home/ResumePreview.astro";

const title = `${t("title")}`;
---
<Layout title={title}>
  <Hero />
  <FeaturedProjects />
  <Experience />
  <Community />
  <Writing />
  <Skills />
  <AboutPreview />
  <ResumePreview />
</Layout>
