---
// src/routes/index.astro

import { t } from "i18n:astro";

import Layout from "../layouts/Layout.astro"

import Navigation from "../components/layout/Navigation.astro";

import Greeter from "../components/home/Greeter.astro";
import Projects from "../components/home/Projects.astro";
import Education from "../components/home/Education.astro";
import Community from "../components/home/Community.astro";
import Experience from "../components/home/Experience.astro";

const title = `${t("title")}`;
---

<Layout title={title}>
  <Greeter />
  <Navigation />
  <Experience />
  <Projects />
  <Education />
  <Community />
</Layout>
