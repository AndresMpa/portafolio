---
// src/routes/index.astro

import { t } from "i18n:astro";
import Layout from "../layouts/Layout.astro";
import Hero from "../components/hero/Hero.astro";
import Experience from "../components/experience/Experience.astro";
import EducationSummary from "../components/education/EducationSummary.astro";
import ProjectFeatured from "../components/project/ProjectFeatured.astro";
import Community from "../components/community/Community.astro";
import Skills from "../components/home/Skills.astro";
import Writing from "../components/home/Writing.astro";

const title = `${t("title")}`;
---
<Layout title={title}>
  <Hero />
  <ProjectFeatured />
  <Experience />
  <EducationSummary />
  <Community />
  <Writing />
  <Skills />
</Layout>
