---
// src/routes/experience/index.astro

import { t, getLocale } from "i18n:astro";

import { getExperience } from "../lib/experience";

import { person } from "../data/person";

import Layout from "../layouts/Layout.astro";

import ExperienceCurrent from "../components/experience/ExperienceCurrent.astro";
import ExperiencePast from "../components/experience/ExperiencePast.astro";

const lang = getLocale();
const entries = await getExperience(lang);
const title = `${person.name} | ${t("experience.title")}`;
const current = entries.filter((e) => e.endDate === null);
const past = entries.filter((e) => e.endDate !== null);
---

<Layout title={title}>
  <section class="max-w-7xl mx-auto px-6 py-6 pb-24">
    <h1 class="text-4xl md:text-5xl font-black leading-tight mb-12">{t("experience.title")}</h1>
    <ExperienceCurrent items={current} />
    <ExperiencePast items={past} />
  </section>
</Layout>
